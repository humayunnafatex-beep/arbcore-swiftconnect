# ARBCore SwiftConnect environment template
# Copy this file to .env for local development or configure the same keys in Vercel.
# Never commit real database URLs, access tokens, passwords, or app secrets.

# Required. Runtime database connection.
# Local development may use: file:./local.db
# Production should use the Supabase pooled PostgreSQL URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Required for Prisma migrations in production.
# Use the Supabase direct/session PostgreSQL URL, not the pooler URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Optional public app URL used by deployment docs, callbacks, and future absolute links.
NEXT_PUBLIC_APP_URL="https://your-domain.example"

# Optional Supabase Auth browser/session settings.
# These are public anon values used by Supabase Auth client helpers, not service-role secrets.
# Leave blank until Supabase Auth is enabled for SaaS login.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Required for production hardening when session signing is enabled.
# Use a long random value from a password manager or secret generator.
SESSION_SECRET="replace_with_a_long_random_secret"

# Optional Phase 3 auth enforcement switch.
# false = current Enterprise Beta/demo access remains available.
# true = protected app routes redirect unauthenticated users to /login.
# Meta webhook routes must remain public even when this is true.
AUTH_ENFORCED=false

# Optional Phase 7 permission enforcement switch.
# false = permissions are documented/checkable but do not hard-block current beta users.
# true = future API/page permission guards can block unauthorized roles.
PERMISSIONS_ENFORCED=false

# Optional OpenAI server key. Leave blank to use the built-in beta fallback responses.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Optional Meta WhatsApp Cloud API server credentials.
# Leave blank until a real Meta app, phone number, and webhook are configured.
# Never expose these values in browser code or documentation.
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_API_VERSION="v21.0"

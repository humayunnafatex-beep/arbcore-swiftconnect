# Local MVP database. Prisma resolves this relative to the prisma/ folder.
DATABASE_URL="file:./local.db"

# Production PostgreSQL direct connection for Prisma migrations.
# Leave empty for local SQLite development.
DIRECT_URL=

# Production session signing secret. Keep private and rotate if exposed.
SESSION_SECRET=

# Optional real OpenAI integration for AI Studio.
# If OPENAI_API_KEY is empty, ARBCore SwiftConnect uses the local mock fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional official Meta WhatsApp Cloud API sandbox integration.
# If these are empty, campaign/test sends use the local mock fallback.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0

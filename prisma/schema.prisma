generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")

}

enum WhatsAppStatus {
  CONNECTED
  PENDING
  DISCONNECTED
}

enum ContactStage {
  NEW_LEAD
  INTERESTED
  ORDERED
  DELIVERED
  FOLLOW_UP
  WON
  LOST
}

enum CampaignStatus {
  DRAFT
  READY
  SCHEDULED
  RUNNING
  SENT
  PAUSED
  FAILED
  ARCHIVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
}

enum CrmDealStatus {
  OPEN
  WON
  LOST
}

enum MessageTemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
  SUPPORT
}

enum MessageTemplateLanguage {
  ENGLISH
  BANGLA
  BANGLISH
}

enum MessageTemplateStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
}

model Company {
  id                     String   @id @default(cuid())
  name                   String
  slug                   String   @unique
  plan                   String   @default("Enterprise")
  businessName           String  @default("ARBCore AI")
  workspaceName          String  @default("Enterprise Workspace")
  phone                  String   @default("")
  website                String   @default("")
  timezone               String   @default("Asia/Dhaka")
  language               String   @default("English")
  notificationFailed     Boolean  @default(true)
  notificationHotLead    Boolean  @default(true)
  notificationBilling    Boolean  @default(true)
  notificationWeekly     Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  whatsappPhoneNumberId String @default("") 
  whatsappAccessToken   String @default("")
  whatsappVerifyToken   String @default("")
  whatsappWebhookUrl    String @default("")
  messengerPageId          String @default("")
  messengerPageAccessToken String @default("")
  messengerVerifyToken     String @default("")
  messengerWebhookUrl      String @default("")

  users           User[]
  whatsappAccounts WhatsAppAccount[]
  contacts        Contact[]
  orders          Order[]
  products        Product[]
  campaigns       Campaign[]
  conversations   Conversation[]
  messageLogs     MessageLog[]
  autoReplyRules  AutoReplyRule[]
  autoReplyEvents AutoReplyEvent[]
  crmDeals        CrmDeal[]
  aiGenerations   AiGeneration[]
  aiUsages        AIUsage[]
  messageTemplates MessageTemplate[]
  webhookEvents   WebhookEvent[]
  conversationStates ConversationState[]
  subscriptions    Subscription[]
  paymentRecords   PaymentRecord[]
}

model User {
  id           String   @id @default(cuid())
  supabaseAuthId String? @unique
  email        String   @unique
  name         String
  role         UserRole @default(AGENT)
  isActive     Boolean  @default(true)
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedConversationStates ConversationState[]
}

model ConversationState {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  channel      String
  contactKey   String
  status       String   @default("OPEN")
  internalNote String   @default("")
  followUpAt   DateTime?
  followUpDone Boolean  @default(false)
  assignedToId String?
  assignedTo   User?    @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([companyId, channel, contactKey])
  @@index([companyId, status])
  @@index([assignedToId])
}

model WhatsAppAccount {
  id              String         @id @default(cuid())
  label           String
  phoneNumber     String         @unique
  businessName    String?
  status          WhatsAppStatus @default(PENDING)
  qualityRating   String         @default("UNKNOWN")
  dailyLimit      Int            @default(10000)
  messagesUsed24h Int            @default(0)
  lastSyncedAt    DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  campaigns     Campaign[]
  conversations Conversation[]
  messageLogs   MessageLog[]
}

model Contact {
  id        String       @id @default(cuid())
  name      String
  phone     String       @unique
  email     String?
  tags      String?
  segment   String?
  stage     ContactStage @default(NEW_LEAD)
  optedIn   Boolean      @default(true)
  doNotContact Boolean   @default(false)
  metadata  Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  conversations Conversation[]
  crmDeals      CrmDeal[]
  messageLogs   MessageLog[]
  orders        Order[]
}

model Product {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name           String
  sku            String   @default("")
  price          Int      @default(0)
  availableSizes String   @default("")
  stockNote      String   @default("")
  imageUrl       String   @default("")
  status         String   @default("ACTIVE")
  notes          String   @default("")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, status])
}

model Order {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  contactId       String?
  contact         Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  channel         String   @default("WHATSAPP")
  customerKey     String   @default("")

  orderNumber     String   @default("")
  modelName       String   @default("")
  size            String   @default("")
  quantity        Int      @default(1)
  unitPrice       Int      @default(0)
  deliveryCharge  Int      @default(0)
  totalAmount     Int      @default(0)

  customerName    String   @default("")
  customerPhone   String   @default("")
  deliveryAddress String   @default("")

  paymentStatus   String   @default("UNPAID")
  orderStatus     String   @default("DRAFT")
  followUpAt       DateTime?
  followUpDone     Boolean  @default(false)

  notes           String   @default("")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId, createdAt])
  @@index([companyId, orderStatus])
  @@index([companyId, paymentStatus])
  @@index([companyId, followUpAt])
  @@index([contactId])
  @@index([companyId, channel, customerKey])
}

model Campaign {
  id                String         @id @default(cuid())
  name              String
  channel           String         @default("WHATSAPP")
  templateName      String
  templateVariables Json?
  targetSegment     String?
  audienceNote      String         @default("")
  audienceStatus    String         @default("")
  audienceTags      String         @default("")
  audienceSearch    String         @default("")
  audienceChannel   String         @default("")
  audienceLimit     Int?
  messageBody       String         @default("")
  status            CampaignStatus @default(DRAFT)
  scheduledAt       DateTime?
  sentAt            DateTime?
  notes             String         @default("")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  companyId         String?
  company           Company?        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  whatsappAccountId String?
  whatsappAccount   WhatsAppAccount? @relation(fields: [whatsappAccountId], references: [id], onDelete: SetNull)
  messageLogs       MessageLog[]
}

model MessageTemplate {
  id          String                  @id @default(cuid())
  name        String
  category    MessageTemplateCategory @default(MARKETING)
  language    MessageTemplateLanguage @default(ENGLISH)
  body        String
  variables   String?
  footerText  String?
  buttonText  String?
  buttonUrl   String?
  status      MessageTemplateStatus   @default(DRAFT)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
}

model Conversation {
  id                String    @id @default(cuid())
  subject           String?
  status            String    @default("OPEN")
  priority          String    @default("NORMAL")
  assignedTo        String?
  lastMessageAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  companyId         String?
  company           Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId         String
  contact           Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  whatsappAccountId String?
  whatsappAccount   WhatsAppAccount? @relation(fields: [whatsappAccountId], references: [id], onDelete: SetNull)
  messages          ConversationMessage[]
}

model ConversationMessage {
  id             String           @id @default(cuid())
  body           String
  direction      MessageDirection
  status         MessageStatus    @default(RECEIVED)
  createdAt      DateTime         @default(now())

  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model MessageLog {
  id                String           @id @default(cuid())
  channel           String           @default("WHATSAPP")
  body              String
  direction         MessageDirection
  status            MessageStatus    @default(QUEUED)
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  createdAt         DateTime         @default(now())

  companyId         String?
  company           Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId         String?
  contact           Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  campaignId        String?
  campaign          Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  whatsappAccountId String?
  whatsappAccount   WhatsAppAccount? @relation(fields: [whatsappAccountId], references: [id], onDelete: SetNull)
}

model WebhookEvent {
  id        String   @id @default(cuid())
  provider  String   @default("whatsapp")
  eventType String?
  payload   Json
  createdAt DateTime @default(now())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([provider])
}

model AutoReplyRule {
  id          String   @id @default(cuid())
  keyword     String
  response    String
  priority    Int      @default(100)
  isActive    Boolean  @default(true)
  matchMode   String   @default("CONTAINS")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AutoReplyEvent {
  id                 String   @id @default(cuid())
  companyId          String
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ruleId             String?
  ruleName           String   @default("")
  channel            String   @default("WHATSAPP")
  customerKey        String   @default("")
  inboundTextPreview String   @default("")
  replyPreview       String   @default("")
  status             String   @default("ATTEMPTED")
  providerMessageId  String   @default("")
  errorMessage       String   @default("")
  createdAt          DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([companyId, channel, createdAt])
  @@index([ruleId])
  @@index([status])
}

model CrmDeal {
  id          String        @id @default(cuid())
  title       String
  value       Float         @default(0)
  stage       ContactStage  @default(NEW_LEAD)
  status      CrmDealStatus @default(OPEN)
  owner       String?
  nextAction  String?
  dueAt       DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  companyId   String?
  company     Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model AiGeneration {
  id        String   @id @default(cuid())
  prompt    String
  context   String?
  output    String
  model     String   @default("mock-arbcore-ai")
  createdAt DateTime @default(now())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AIUsage {
  id               String   @id @default(cuid())
  generationType   String
  model            String
  provider         String   @default("mock")
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  usedFallback     Boolean  @default(false)
  errorMessage     String?
  createdAt        DateTime @default(now())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([generationType])
}

model Subscription {
  id                 String   @id @default(cuid())
  companyId          String
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan               String   @default("ENTERPRISE_BETA")
  status             String   @default("ACTIVE")
  billingMode        String   @default("MANUAL")
  startedAt          DateTime @default(now())
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  notes              String   @default("")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  paymentRecords PaymentRecord[]

  @@index([companyId])
  @@index([status])
}

model PaymentRecord {
  id             String        @id @default(cuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  amount         Int
  currency       String        @default("BDT")
  method         String        @default("MANUAL")
  status         String        @default("PENDING")
  transactionRef String        @default("")
  paidAt         DateTime?
  notes          String        @default("")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([companyId])
  @@index([subscriptionId])
  @@index([status])
}
